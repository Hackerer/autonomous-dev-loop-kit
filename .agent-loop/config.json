{
  "version": 1,
  "mode": "autonomous-dev-loop",
  "git": {
    "strategy": "direct-push",
    "remote": "origin",
    "base_branch": "main",
    "branch_prefix": "auto-loop/v",
    "require_remote": true,
    "require_github_remote": true,
    "ask_user_if_remote_unclear": true
  },
  "validation": {
    "stop_on_first_failure": false,
    "commands": [
      {
        "name": "validate-kit",
        "command": "python3 .agent-loop/scripts/validate-kit.py",
        "required": true
      }
    ]
  },
  "discovery": {
    "require_research_before_goal_selection": true,
    "minimum_research_inputs": 3,
    "require_committee_review": true,
    "require_post_validation_reflection": true,
    "archetype_profiles": {
      "default_profile": "baseline",
      "profiles": {
        "baseline": {
          "label": "Baseline Repo",
          "repo_archetypes": [
            "general-repo",
            "autonomous-loop-repo"
          ],
          "required_signals": [
            "collection_timestamp",
            "repo_root",
            "git_branch",
            "git_remote",
            "worktree_clean",
            "languages",
            "tooling_signals",
            "validation_commands",
            "target_outcome",
            "constraints",
            "direct_evidence"
          ],
          "committee_emphasis": [
            "goal clarity",
            "scope discipline",
            "validation truthfulness"
          ]
        },
        "agent-skill-kit": {
          "label": "Agent Skill Kit",
          "repo_archetypes": [
            "agent-skill-kit"
          ],
          "required_signals": [
            "collection_timestamp",
            "repo_root",
            "git_branch",
            "git_remote",
            "worktree_clean",
            "languages",
            "tooling_signals",
            "repo_archetype",
            "validation_commands",
            "target_outcome",
            "constraints",
            "direct_evidence"
          ],
          "committee_emphasis": [
            "repo portability",
            "operator clarity",
            "release safety"
          ]
        },
        "service-backend": {
          "label": "Service Backend",
          "repo_archetypes": [
            "service-backend"
          ],
          "required_signals": [
            "collection_timestamp",
            "repo_root",
            "git_branch",
            "git_remote",
            "worktree_clean",
            "languages",
            "tooling_signals",
            "validation_commands",
            "target_outcome",
            "constraints",
            "direct_evidence"
          ],
          "committee_emphasis": [
            "runtime safety",
            "operational auditability",
            "stop conditions"
          ]
        },
        "frontend-app": {
          "label": "Frontend App",
          "repo_archetypes": [
            "frontend-app"
          ],
          "required_signals": [
            "collection_timestamp",
            "repo_root",
            "git_branch",
            "git_remote",
            "worktree_clean",
            "languages",
            "tooling_signals",
            "validation_commands",
            "target_outcome",
            "constraints",
            "direct_evidence"
          ],
          "committee_emphasis": [
            "operator clarity",
            "scope crispness",
            "handoff quality"
          ]
        }
      }
    }
  },
  "committee": {
    "enabled": true,
    "review_mode": "requirements-and-review-council",
    "personas": {
      "outcome-pm": {
        "label": "Outcome PM",
        "group": "product-council",
        "responsibility": "Judge whether the iteration materially advances the target outcome.",
        "focus": "goal mapping, why now, expected outcome, release objective",
        "output_fields": [
          "stance",
          "candidate_goal",
          "why_now",
          "expected_outcome",
          "success_signal",
          "reject_reasons"
        ],
        "release_output_fields": [
          "release_objective",
          "target_user_value",
          "why_now",
          "packaging_rationale"
        ]
      },
      "scope-pm": {
        "label": "Scope PM",
        "group": "product-council",
        "responsibility": "Compress the iteration into the smallest testable boundary and keep bundled releases coherent.",
        "focus": "scope in, scope out, stop line, release packaging boundary",
        "output_fields": [
          "stance",
          "scope_in",
          "scope_out",
          "mvp_boundary",
          "deferred_items",
          "stop_line"
        ],
        "release_output_fields": [
          "scope_in",
          "scope_out",
          "deferred_items",
          "release_acceptance"
        ]
      },
      "user-pm": {
        "label": "User PM",
        "group": "product-council",
        "responsibility": "Protect operator clarity, documentation consistency, handoff quality, and the release story users will actually perceive.",
        "focus": "user value, cognitive cost, explainability, launch story",
        "output_fields": [
          "stance",
          "user_value",
          "cognitive_cost",
          "explainability_gaps",
          "documentation_impact"
        ],
        "release_output_fields": [
          "target_user_value",
          "launch_story",
          "documentation_impact"
        ]
      },
      "repo-architect": {
        "label": "Repo Architect",
        "group": "architecture-council",
        "responsibility": "Protect source-of-truth boundaries, repo portability, and script ownership.",
        "focus": "structural fit, coupling, portability",
        "output_fields": [
          "stance",
          "structural_fit",
          "source_of_truth_check",
          "portability_impact",
          "coupling_risks"
        ]
      },
      "protocol-architect": {
        "label": "Protocol Architect",
        "group": "architecture-council",
        "responsibility": "Protect gate ordering, state transitions, and deterministic stop behavior.",
        "focus": "protocol clarity, state transitions, stop conditions",
        "output_fields": [
          "stance",
          "protocol_clarity",
          "state_transition_impact",
          "gate_integrity",
          "stop_condition_gaps"
        ]
      },
      "quality-safety-architect": {
        "label": "Quality & Safety Architect",
        "group": "architecture-council",
        "responsibility": "Protect validation truthfulness, publish safety, and release trustworthiness.",
        "focus": "validation readiness, publish safety, auditability",
        "output_fields": [
          "stance",
          "validation_readiness",
          "publish_safety",
          "trustworthiness_risk",
          "stop_triggers"
        ]
      },
      "solo-builder": {
        "label": "Solo Builder",
        "group": "operator-council",
        "responsibility": "Protect low-ceremony adoption for solo and small-project workflows.",
        "focus": "setup cost, iteration friction, practical benefit",
        "output_fields": [
          "stance",
          "setup_cost",
          "iteration_friction",
          "small_project_fit",
          "practical_benefit"
        ]
      },
      "team-maintainer": {
        "label": "Team Maintainer",
        "group": "operator-council",
        "responsibility": "Protect handoff quality, traceability, and later debugging support.",
        "focus": "maintainability, handoff, traceability",
        "output_fields": [
          "stance",
          "maintainability_impact",
          "handoff_quality",
          "traceability",
          "debugging_support"
        ]
      },
      "security-compliance-user": {
        "label": "Security & Compliance User",
        "group": "operator-council",
        "responsibility": "Protect audit chain, explicit controls, and minimum-surprise automation.",
        "focus": "audit chain, policy alignment, evidence gaps",
        "output_fields": [
          "stance",
          "audit_chain",
          "policy_alignment",
          "risk_surface",
          "control_recommendation"
        ]
      },
      "delivery-secretary": {
        "label": "Delivery Secretary",
        "group": "secretariat",
        "responsibility": "Converge committee output into an executable scope decision without inventing new scope.",
        "focus": "selected goal, scope boundaries, next action",
        "output_fields": [
          "selected_goal",
          "why_selected",
          "scope_in",
          "scope_out",
          "required_validation",
          "next_action"
        ]
      },
      "audit-secretary": {
        "label": "Audit Secretary",
        "group": "secretariat",
        "responsibility": "Translate committee output into durable, auditable state fields.",
        "focus": "decision record, evidence refs, open gaps",
        "output_fields": [
          "research_summary",
          "committee_feedback_summary",
          "evidence_refs",
          "decision_record",
          "open_gaps",
          "dissent_record"
        ]
      },
      "independent-evaluator": {
        "label": "Independent Evaluator",
        "group": "evaluator",
        "responsibility": "Score the final scope decision independently before implementation starts.",
        "focus": "goal clarity, scope fitness, repo safety, validation readiness",
        "output_fields": [
          "rubric_version",
          "scores",
          "weighted_score",
          "result",
          "minimum_fixes_required"
        ]
      }
    },
    "councils": [
      {
        "id": "product-council",
        "label": "Product Council",
        "responsibility": "Choose the smallest worthwhile goal and keep the scope user-meaningful.",
        "persona_ids": [
          "outcome-pm",
          "scope-pm",
          "user-pm"
        ]
      },
      {
        "id": "architecture-council",
        "label": "Architecture Council",
        "responsibility": "Stress-test structure, protocol integrity, and release safety before implementation.",
        "persona_ids": [
          "repo-architect",
          "protocol-architect",
          "quality-safety-architect"
        ]
      },
      {
        "id": "operator-council",
        "label": "Operator Council",
        "responsibility": "Protect lightweight adoption, handoff quality, and auditability for real operators.",
        "persona_ids": [
          "solo-builder",
          "team-maintainer",
          "security-compliance-user"
        ]
      }
    ],
    "secretariat": {
      "persona_ids": [
        "delivery-secretary",
        "audit-secretary"
      ]
    },
    "evaluator": {
      "persona_id": "independent-evaluator",
      "rubric_ref": ".agent-loop/references/iteration-readiness-rubric.json",
      "require_pass_before_implementation": true,
      "implementation_gate_mode": "blocking",
      "result_thresholds": {
        "pass": 4.0,
        "revise": 3.0,
        "fail": 0.0
      }
    },
    "escalation_policy": {
      "repeat_evaluator_revise_or_fail": 2,
      "repeat_validation_failures": 2,
      "repeat_goal_churn": 2
    },
    "roles": [
      {
        "id": "product-manager",
        "label": "Product Manager Committee",
        "responsibility": "Challenge user value, scope discipline, sequencing, and acceptance criteria before implementation starts.",
        "members": [
          {
            "name": "Maya Chen",
            "style": "growth-oriented pragmatist",
            "focus": "user value, scope trimming, launch readiness"
          },
          {
            "name": "Idris Kapoor",
            "style": "metrics-driven operator",
            "focus": "success metrics, acceptance clarity, feedback loops"
          },
          {
            "name": "Elena Park",
            "style": "support-conscious product lead",
            "focus": "operational burden, rollout risk, edge-case clarity"
          }
        ]
      },
      {
        "id": "technical-architect",
        "label": "Technical Architect Committee",
        "responsibility": "Challenge architecture, interfaces, migration cost, validation strategy, and operational safety.",
        "members": [
          {
            "name": "Victor Hale",
            "style": "simplicity-first systems architect",
            "focus": "failure isolation, minimal surface area, clean boundaries"
          },
          {
            "name": "Priya Raman",
            "style": "testability-focused platform architect",
            "focus": "interface contracts, migration paths, validation depth"
          },
          {
            "name": "Jonas Meyer",
            "style": "reliability and observability specialist",
            "focus": "runtime safety, instrumentation, rollback posture"
          }
        ]
      },
      {
        "id": "user",
        "label": "User Committee",
        "responsibility": "Challenge the plan from concrete usage scenarios, day-to-day friction, trust, and clarity.",
        "members": [
          {
            "name": "Leo Zhang",
            "style": "time-starved mobile user",
            "focus": "speed to value, simple outputs, low interaction cost"
          },
          {
            "name": "Sofia Martinez",
            "style": "risk-averse careful operator",
            "focus": "explainability, guardrails, confidence before action"
          },
          {
            "name": "Ben Carter",
            "style": "power user and workflow optimizer",
            "focus": "control, configurability, useful edge-case behavior"
          }
        ]
      }
    ]
  },
  "reporting": {
    "directory": "docs/reports",
    "filename_pattern": "v{iteration}.md",
    "release_directory": "docs/releases",
    "release_filename_pattern": "R{release}.md"
  },
  "usage_logging": {
    "enabled": true,
    "path": ".agent-loop/data/usage-log.jsonl"
  },
  "planning": {
    "require_explicit_target_iterations": true,
    "max_iterations_per_session": 200,
    "max_releases_per_session": 30,
    "max_consecutive_failures": 2,
    "goal_selection_policy": "highest-priority-pending",
    "release": {
      "require_release_plan": true,
      "min_goals_per_release": 2,
      "max_goals_per_release": 5,
      "default_goals_per_release": 3
    }
  },
  "stop_conditions": [
    "requirements-conflict",
    "shared-system-risk",
    "missing-credentials",
    "unclear-git-publication-target",
    "consecutive-validation-failures",
    "no-high-value-task-left"
  ]
}
